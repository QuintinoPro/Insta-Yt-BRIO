# ─── Branding ──────────────────────────────────────────────────────────────────
# Personalize o dashboard com o nome do seu projeto.
PIPELINE_BRAND_NAME=My Pipeline
PIPELINE_BRAND_LOGO=YT
PIPELINE_TITLE=Instagram → YouTube Pipeline

# ─── Instagram ────────────────────────────────────────────────────────────────
# Session ID do cookie do Instagram (obrigatório para download).
# Como obter: Chrome → F12 → Application → Cookies → instagram.com → sessionid
INSTAGRAM_SESSION_ID=

# ─── YouTube OAuth ────────────────────────────────────────────────────────────
# Faça o download do client_secrets.json no Google Cloud Console:
# APIs & Services → Credentials → OAuth 2.0 Client IDs → Download JSON
YOUTUBE_CLIENT_SECRETS_FILE=auth/client_secrets.json
YOUTUBE_TOKEN_FILE=auth/token.json

# ─── Pipeline ─────────────────────────────────────────────────────────────────
TARGET_INSTAGRAM_PROFILE=seu_perfil_instagram
DOWNLOAD_DIR=downloads
METADATA_FILE=metadata/videos.json
REPORT_FILE=metadata/report.csv
LOG_FILE=logs/pipeline.log

# Horário de publicação agendada no YouTube (formato 24h, fuso UTC)
UPLOAD_HOUR=13
UPLOAD_MINUTE=0

# Máximo de vídeos a baixar do Instagram por execução
MAX_COLLECT_PER_RUN=30

# Máximo de uploads ao YouTube por execução (quota: ~6/dia)
MAX_UPLOADS_PER_RUN=6
